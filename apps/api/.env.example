# MEMPAS Backend Environment Configuration (template)
# Copy to apps/api/.env and fill in real values (do NOT commit .env)

# ── LLM (Qwen-VL via DashScope OpenAI-compatible endpoint) ────────────────
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_MODEL=qwen3-vl-plus
LLM_VISION_MODEL_FALLBACK=qwen-vl-max
LLM_PROVIDER=qwen_vl

# ── File upload storage ───────────────────────────────────────────────────
UPLOAD_DIR=data/uploads

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
