# MEMPAS Backend Environment Configuration (template)
# Copy to apps/api/.env and fill in real values (do NOT commit .env)

# ── LLM — DashScope (Alibaba Cloud) ─────────────────────────────────────
DASHSCOPE_API_KEY=sk-replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER=dashscope_ocr  # dashscope_ocr | mock
DASHSCOPE_OCR_MODEL=qwen-vl-ocr-latest
DASHSCOPE_LLM_MODEL=qwen3.6-flash

# ── File upload storage ───────────────────────────────────────────────────
UPLOAD_DIR=data/uploads

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
